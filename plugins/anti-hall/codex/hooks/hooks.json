{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/verify-first-full.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/verify-first-orch.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/graphify-session.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/devswarm-child-role.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/version-alert.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/codex-availability.js\"", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/verify-first.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/task-tracker.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/limit-conserve-inject.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/devswarm-parent-inbox.js\"", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/devswarm-child-turn.js\"", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/git-guard.js\"", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/command-guard.js\"", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/graphify-guard.js\"", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/merge-gate.js\"", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/task-guard.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/tasklist-guard.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/graphify-reminder.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/speculation-guard.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/speculation-judge.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/devswarm-parent-gate.js\"", "timeout": 30 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/devswarm-child-gate.js\"", "timeout": 30 }
        ]
      }
    ]
  }
}
