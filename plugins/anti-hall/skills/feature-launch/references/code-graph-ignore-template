# code-graph-ignore-template
#
# Starter exclusion list for building a CODE GRAPH on a large repo (A1).
# Copy to the repo root (e.g. as `.graphignore` or your graph tool's ignore
# file) and customize. The goal is a sensible file count BEFORE running the
# graph tool — exclude generated, vendored, and binary paths that add noise
# without architectural signal.
#
# One glob per line; lines beginning with `#` are comments.

# Dependencies / vendored code
node_modules/
vendor/
.venv/
venv/
__pycache__/
.dart_tool/
Pods/
.pub-cache/

# Build / generated output
build/
dist/
out/
target/
coverage/
*.g.dart
*.freezed.dart
*.pb.dart
*.min.js
*.map

# Version control / IDE / OS
.git/
.idea/
.vscode/
.DS_Store

# Lockfiles and large data
*.lock
package-lock.json
yarn.lock
pubspec.lock
*.csv
*.parquet
*.sqlite

# Media / binaries
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.zip
*.tar
*.gz
*.woff
*.woff2
*.ttf
